QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=mediq_wait_events
DATA_FILE=../data/raw/TTSH Oct 25 - 04 May 26 - WaitTimeAdded.xlsx

# OPENAI_API_KEY is required — embeddings (wait-event + SOP RAG search) and the LLM
# phrasing/Q&A steps all call the OpenAI API. There is no local/offline fallback.
OPENAI_API_KEY=
LLM_MODEL=gpt-5.5
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
CORS_ORIGINS=http://localhost:3000

# SOP & healthcare Q&A RAG
QDRANT_SOP_COLLECTION=mediq_sop_docs
SOP_DOCS_DIR=../data/sop_docs
